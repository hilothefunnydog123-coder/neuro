# --- Brains: turns a vague task into an objective + extracts results ---
# Free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.0-flash

# --- Voice: actually dials the phone. Get a key + trial credits at bland.ai ---
BLAND_API_KEY=your_bland_key

# Provider: "bland" for real calls, "mock" for the scripted offline demo.
# Leave as "mock" to build/pitch with zero accounts or credits.
CALL_PROVIDER=mock
