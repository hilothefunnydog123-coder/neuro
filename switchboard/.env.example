# --- Brains: turns a vague task into an objective + extracts results ---
# Free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.0-flash

# --- Voice: actually dials the phone ---
# Provider: "vapi" for real calls, "mock" for the scripted offline demo.
# Leave as "mock" to build/pitch with zero accounts or credits.
CALL_PROVIDER=mock

# Vapi (recommended). Get a key at https://vapi.ai, then create/import a phone
# number in the dashboard and paste its ID below.
VAPI_API_KEY=your_vapi_private_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_VOICE=alloy
VAPI_MODEL=gpt-4o

# Bland.ai (alternative). Only used when CALL_PROVIDER=bland.
BLAND_API_KEY=
